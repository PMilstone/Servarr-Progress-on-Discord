# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Discord webhook URL (required)
WEBHOOK_URL=https://discord.com/api/webhooks/...

# qBittorrent web UI base URL (include http:// or https:// and port if needed)
QB_URL=http://127.0.0.1:8080

# qBittorrent credentials (leave blank if not required)
QB_USER=
QB_PASS=

# Port for the webhook server (default 8383)
PORT=8383


# =============================================================================
# SONARR/RADARR INTEGRATION (Optional)
# =============================================================================

# Sonarr configuration (optional - enables automatic webhook creation)
# Get API key from Sonarr: Settings → General → Security → API Key
SONARR_URL=http://127.0.0.1:8989
SONARR_API_KEY=

# Radarr configuration (optional - enables automatic webhook creation)
# Get API key from Radarr: Settings → General → Security → API Key
RADARR_URL=http://127.0.0.1:7878
RADARR_API_KEY=


# =============================================================================
# MESSAGE DISPLAY (Optional)
# =============================================================================

# Optional message content to send with each embed
MESSAGE=Download status update

# Optional Discord message ID - the service will edit this message instead of creating new ones
# Leave blank to create a new message on each update, or get from Discord:
# 1. Enable Developer Mode in Discord (User Settings → Advanced)
# 2. Right-click a message in your channel
# 3. Select "Copy Message ID"
# The setup wizard can automatically capture this for you
MESSAGE_ID=


# =============================================================================
# EMBED CUSTOMIZATION (Optional)
# =============================================================================

# Embed display toggles (true/false)
EMBED_SHOW_DOWNLOAD_SPEED=false
EMBED_SHOW_UPLOAD_SPEED=false
EMBED_SHOW_ETA=true
EMBED_SHOW_TIME_ADDED=false
EMBED_SHOW_TIME_SINCE_STARTED=false


# =============================================================================
# ADVANCED CONFIGURATION (Optional)
# =============================================================================

# Poll interval in seconds while active downloads exist
ACTIVE_UPDATE_INTERVAL=6

# Maximum log file size in bytes before rotation (default 10485760 = 10MB)
# When the log reaches this size, it will be rotated and up to 3 backup files kept
LOG_MAX_SIZE=10485760

# qBittorrent category filter (comma-separated, case-insensitive substring match)
# Only torrents with categories containing these strings will be shown
# Leave blank or comment out to show ALL torrents regardless of category
# QB_CATEGORIES=tv-arr,movies-arr